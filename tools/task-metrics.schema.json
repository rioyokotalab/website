{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://www.rio.scrc.iir.isct.ac.jp/tools/task-metrics.schema.json",
  "title": "YOKOTA Lab task metrics JSONL row",
  "description": "Backward-compatible schema for legacy v1 bookkeeping rows and benchmark-aware v2 rows.",
  "oneOf": [
    {
      "title": "Legacy v1 row",
      "type": "object",
      "required": ["date", "task_type", "agent", "tier", "duration_ms", "success", "note"],
      "properties": {
        "schema_version": {"type": "integer", "maximum": 1},
        "date": {"type": "string", "minLength": 1},
        "task_type": {"type": "string", "minLength": 1},
        "agent": {"type": "string", "minLength": 1},
        "tier": {"type": "string", "minLength": 1},
        "model": {"type": "string"},
        "duration_ms": {"type": ["integer", "null"]},
        "success": {"type": "boolean"},
        "note": {"type": "string"}
      },
      "additionalProperties": true
    },
    {
      "title": "Version 2 benchmark/run row",
      "type": "object",
      "required": [
        "schema_version", "date", "task_type", "agent", "tier", "duration_ms", "success", "note",
        "run_id", "run_label", "task_id", "model", "effort", "outcome",
        "capability_score", "critical_pass", "capability_pass", "f2p", "p2p", "scope", "completion",
        "input_tokens", "cached_input_tokens", "output_tokens", "reasoning_output_tokens", "effective_tokens",
        "prompt_bytes", "instruction_bytes", "completed_commands", "failed_commands", "tool_output_chars",
        "setup_duration_ms", "worker_duration_ms", "grader_duration_ms", "review_duration_ms", "total_duration_ms",
        "changed_files", "retries", "escalation", "failure_phase", "failure_category", "artifact"
      ],
      "properties": {
        "schema_version": {"const": 2},
        "date": {"type": "string", "minLength": 1},
        "task_type": {"type": "string", "minLength": 1},
        "agent": {"type": "string", "minLength": 1},
        "tier": {"type": "string", "minLength": 1},
        "duration_ms": {"type": "integer", "minimum": 0},
        "success": {"type": "boolean"},
        "note": {"type": "string", "maxLength": 500},
        "run_id": {"type": "string", "minLength": 1},
        "run_label": {"type": "string", "minLength": 1},
        "task_id": {"type": "string", "minLength": 1},
        "model": {"type": "string", "minLength": 1},
        "effort": {"enum": ["low", "medium", "high"]},
        "outcome": {"enum": ["passed", "failed", "partial", "timeout", "error", "excluded"]},
        "capability_score": {"type": ["number", "null"], "minimum": 0, "maximum": 100},
        "critical_pass": {"type": ["boolean", "null"]},
        "capability_pass": {"type": "boolean"},
        "f2p": {"type": ["number", "null"], "minimum": 0},
        "p2p": {"type": ["number", "null"], "minimum": 0},
        "scope": {"type": ["number", "null"], "minimum": 0},
        "completion": {"type": ["number", "null"], "minimum": 0},
        "input_tokens": {"type": ["integer", "null"], "minimum": 0},
        "cached_input_tokens": {"type": ["integer", "null"], "minimum": 0},
        "output_tokens": {"type": ["integer", "null"], "minimum": 0},
        "reasoning_output_tokens": {"type": ["integer", "null"], "minimum": 0},
        "effective_tokens": {"type": ["integer", "null"], "minimum": 0},
        "prompt_bytes": {"type": ["integer", "null"], "minimum": 0},
        "instruction_bytes": {"type": ["integer", "null"], "minimum": 0},
        "completed_commands": {"type": "integer", "minimum": 0},
        "failed_commands": {"type": "integer", "minimum": 0},
        "tool_output_chars": {"type": "integer", "minimum": 0},
        "setup_duration_ms": {"type": ["integer", "null"], "minimum": 0},
        "worker_duration_ms": {"type": ["integer", "null"], "minimum": 0},
        "grader_duration_ms": {"type": ["integer", "null"], "minimum": 0},
        "review_duration_ms": {"type": ["integer", "null"], "minimum": 0},
        "total_duration_ms": {"type": "integer", "minimum": 0},
        "changed_files": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
        "retries": {"type": "integer", "minimum": 0},
        "escalation": {"type": ["string", "null"]},
        "failure_phase": {"type": ["string", "null"]},
        "failure_category": {"type": ["string", "null"]},
        "artifact": {"type": ["string", "null"]}
      },
      "additionalProperties": false
    }
  ]
}
